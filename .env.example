# ============================================================
# Lucky Birr – Environment Variables
# Copy this file to .env and fill in the values.
# Lines marked [REQUIRED] must be set for the app to function.
# Lines marked [optional] can be omitted locally.
# NEVER commit .env with real secrets.
# ============================================================

# Server
NODE_ENV=production          # optional – defaults to development
PORT=10000                   # optional – defaults to 10000

# Public URL of this deployment (used for CORS)
# [REQUIRED in production]
WEBSITE_URL=https://lucky-birr.onrender.com

# JWT signing secret – min 32 random characters
# [REQUIRED]
JWT_SECRET=replace-with-a-random-secret-at-least-32-chars

# Comma-separated list of admin email addresses
# [optional – no admin panel without this]
ADMIN_EMAILS=admin@example.com

# Supabase – [REQUIRED for database features]
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=screenshots  # optional – defaults to "screenshots"

# Telegram outbound notifications – [optional]
# Set both to enable admin notifications on new submissions.
TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=

# Telegram inbound webhook – [optional]
# Set to enable the /webhook/:secret endpoint.
# Must be different from TELEGRAM_BOT_TOKEN.
TELEGRAM_WEBHOOK_SECRET=
