# ==============================================================
# Lucky Birr – Environment Variables
# ==============================================================
# Copy this file to `.env` for local development.
# Never commit the real `.env` file to version control.
# Set secrets via the Render dashboard (not in render.yaml).

# ── Server ──────────────────────────────────────────────────
# Port the HTTP server listens on.
# Render injects this automatically; leave it unset locally to
# use the default (3000).
PORT=3000

# Set to "production" on Render (already handled in render.yaml).
NODE_ENV=development

# ── Telegram Bot ─────────────────────────────────────────────
# Token from @BotFather. Required to receive payment-proof data
# sent by the Mini App via tg.sendData().
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── App URL ──────────────────────────────────────────────────
# Full public URL of this deployment.
# Used as the Telegram Mini App URL and for share links.
WEBAPP_URL=https://your-app.onrender.com
