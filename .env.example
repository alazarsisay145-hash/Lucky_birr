# Lucky Birr – Environment Variables
# Copy this file to .env and fill in the values before running in production.

# Server port (default: 3000)
PORT=3000

# Telegram Bot token (from @BotFather)
BOT_TOKEN=your-telegram-bot-token-here

# Public URL where the Mini App is hosted
WEBAPP_URL=https://your-domain.com

# Admin Telegram user ID (used to restrict admin commands)
ADMIN_TELEGRAM_ID=your-admin-telegram-user-id

# Node environment
NODE_ENV=production
