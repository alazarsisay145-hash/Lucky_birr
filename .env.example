# ============================================================
# Lucky Birr – Environment Variables
# Copy this file to .env and fill in the values.
# Lines marked [REQUIRED] must be set for the app to function.
# Lines marked [optional] can be omitted locally.
# NEVER commit .env with real secrets.
# ============================================================

# Server
NODE_ENV=production          # optional – defaults to development
PORT=10000                   # optional – defaults to 10000

# Public URL of this deployment (used for CORS)
# [REQUIRED in production]
# Must be a valid HTTPS URL. No trailing slash.
# Example: https://lucky-birr.onrender.com
WEBSITE_URL=https://lucky-birr.onrender.com

# JWT signing secret – min 32 random characters
# [REQUIRED]
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-secret-at-least-32-chars

# Comma-separated list of admin email addresses
# [optional – no admin panel without this]
ADMIN_EMAILS=admin@example.com

# Supabase – [REQUIRED for database features]
# SUPABASE_URL: e.g. https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: service_role key (keep server-side only, never expose to clients)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=screenshots  # optional – defaults to "screenshots"

# Telegram outbound notifications – [optional]
# Set BOTH to enable admin notifications on new submissions.
# TELEGRAM_BOT_TOKEN: token from @BotFather, format: 123456789:ABCdef...
# ADMIN_CHAT_ID: your Telegram user or group chat ID (numeric)
TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=

# Telegram inbound webhook – [optional]
# Set to enable the /webhook/:secret endpoint.
# Must be a long random string (not the same as TELEGRAM_BOT_TOKEN).
# Register with: https://api.telegram.org/bot{YOUR_TOKEN}/setWebhook?url=https://lucky-birr.onrender.com/webhook/{YOUR_SECRET}
TELEGRAM_WEBHOOK_SECRET=
